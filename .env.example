# Static Code Analyzer - Environment Configuration
# Copy this file to .env and fill in the values

# GitHub App Configuration
GITHUB_APP_ID=
GITHUB_PRIVATE_KEY=
GITHUB_WEBHOOK_SECRET=

# Output Directory
OUTPUT_DIR=./output

# Server Configuration
PORT=3000
HOST=0.0.0.0



# Logging
LOG_LEVEL=info
LOG_FILE=./logs/sca.log

# Database (Optional)
DATABASE_ENABLED=false
DATABASE_TYPE=mongodb
DATABASE_URL=mongodb://localhost:27017/sca

# Security
ALLOWED_ORIGINS=github.com

# Processing
ENABLE_INCREMENTAL_INDEXING=true
MAX_DIFF_SIZE=5000
BATCH_SIZE=100
